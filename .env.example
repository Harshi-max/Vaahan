# ASR API Keys (set in .env after copying this file)
DEEPGRAM_API_KEY=your_deepgram_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_APPLICATION_CREDENTIALS=path/to/google-credentials.json
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

# Model configuration
WHISPER_MODEL=base
FASTER_WHISPER_MODEL=base
FASTER_WHISPER_DEVICE=auto
FASTER_WHISPER_COMPUTE_TYPE=int8
VOSK_MODEL_PATH=data/models/vosk-model-small-en-in-0.4

# Indic ASR (optional HuggingFace)
INDIC_ASR_MODEL=ai4bharat/indicwav2vec-hindi
ENABLE_INDIC_ASR=false

# Pipeline
PROJECT_ROOT=.
DATA_DIR=data
MAX_WORKERS=2
ENABLE_CACHE=true
CACHE_DIR=data/outputs/.cache

# Deepgram options
DEEPGRAM_MODEL=nova-2
DEEPGRAM_LANGUAGE=hi

# Google STT
GOOGLE_STT_LANGUAGE_CODE=hi-IN
